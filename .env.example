# Copy to .env.local for local development. Never commit .env.local — it is gitignored.
# In production (e.g. Vercel), set these in the host dashboard only.

# Stripe secret key (Dashboard → Developers → API keys). Server-only.
STRIPE_SECRET_KEY=

# Public site URL for Stripe redirects & absolute links, no trailing slash.
# Vercel Production: use the exact URL visitors use (www vs apex must match, or Stripe return can 404).
# Fallback if unset: see lib/site-url.ts. Local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://mediaarise.com

# Optional: donation currency (default cad)
NEXT_PUBLIC_DONATION_CURRENCY=cad

# Webhook signing secret for this deployment’s webhook URL (Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=
