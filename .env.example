# Copy to .env.local for local development. Never commit .env.local — it is gitignored.
# In production (e.g. Vercel), set these in the host dashboard only.

# Stripe secret key — same StoryCruz Films account as video-production-manager is OK.
# Ministry donations are distinguished by checkout product name + metadata (no invoice_id).
# Server-only; never expose to the client.
STRIPE_SECRET_KEY=

# Public site URL, no trailing slash. Example: https://www.your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: donation currency (default cad)
NEXT_PUBLIC_DONATION_CURRENCY=cad

# Webhook signing secret for this deployment’s webhook URL (Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=
